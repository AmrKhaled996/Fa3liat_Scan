{
  "expo": {
    "name": "Fa3liat Scan",
    "slug": "Fa3liat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/FLogo.png",
    "primaryColor": "#BB52E0",
    "backgroundColor": "#BB52E0",
    "scheme": "fa3liat",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/FLogo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "permissions": [
          "android.permission.CAMERA",
          "android.permission.CAMERA"
        ]
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.Fa3liat"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/FLogo.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/FLogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#BB52E0",
          "dark": {
            "backgroundColor": "#BB52E0"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e5e509f6-c7fe-4a3f-bec8-82ec244ddc95"
      }
    }
  }
}
